# Prisma 連線字串
# 開發環境用 SQLite，正式環境改為 postgresql://...
DATABASE_URL="file:./dev.db"

# iron-session 簽章密鑰（至少 32 字元）
# 生成：openssl rand -base64 48
SESSION_SECRET="please-change-me-to-a-random-32-or-more-chars-secret"

# PII 加密金鑰（AES-256-GCM，需 32 bytes 的 base64）
# 生成：openssl rand -base64 32
PII_ENCRYPTION_KEY="please-change-me-32-byte-base64-encoded-key-here="

# 應用 URL（cookie 範圍）
NEXT_PUBLIC_APP_URL="http://localhost:3000"
