# PostgreSQL 連線字串
# Vercel Postgres / Neon / Supabase 提供的 URI 直接貼上
# 例：postgresql://user:pass@host.neon.tech/dbname?sslmode=require
DATABASE_URL=""

# iron-session 簽章密鑰（至少 32 字元）
# 生成：node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=""

# PII 加密金鑰（AES-256-GCM，必須是 32 bytes 的 base64）
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PII_ENCRYPTION_KEY=""

# 首次部署用：自動建立第一位 HR 管理員
# 部署後第一次登入請立刻改密碼，之後可以從環境變數移除
INITIAL_ADMIN_EMAIL="hr@yourcompany.com"
INITIAL_ADMIN_PASSWORD="CHANGE-ME-at-least-8-chars"
INITIAL_ADMIN_NAME="HR Admin"

# 應用 URL（cookie 範圍 / 通知信件用）
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
